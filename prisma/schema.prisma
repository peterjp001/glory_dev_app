generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model bible_verses_hcv {
  id      BigInt @id
  book    Int    @db.SmallInt
  chapter Int    @db.SmallInt
  verse   Int    @db.SmallInt
  text    String

  @@index([book, chapter, verse], map: "idx_hcv_bcv")
  @@index([book], map: "idx_hcv_book")
}

model bible_verses_kjv {
  id      BigInt @id
  book    Int    @db.SmallInt
  chapter Int    @db.SmallInt
  verse   Int    @db.SmallInt
  text    String

  @@index([book, chapter, verse], map: "idx_kjv_bcv")
  @@index([book], map: "idx_kjv_book")
}

model bible_verses_rvg {
  id      BigInt @id
  book    Int    @db.SmallInt
  chapter Int    @db.SmallInt
  verse   Int    @db.SmallInt
  text    String

  @@index([book, chapter, verse], map: "idx_rvg_bcv")
  @@index([book], map: "idx_rvg_book")
}

model bible_verses_segond_1910 {
  id      BigInt @id
  book    Int    @db.SmallInt
  chapter Int    @db.SmallInt
  verse   Int    @db.SmallInt
  text    String

  @@index([book, chapter, verse], map: "idx_seg_bcv")
  @@index([book], map: "idx_seg_book")
}

model reading_plan {
  id       Int  @id @db.SmallInt
  year     Int  @db.SmallInt
  day      Int  @db.SmallInt
  month    Int  @db.SmallInt
  readings Json

  @@index([year, month, day], map: "idx_reading_plan_lookup")
}
