generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model bible_verses_hcv {
  id      BigInt @id(map: "idx_16596_primary") @default(autoincrement())
  book    Int    @db.SmallInt
  chapter Int    @db.SmallInt
  verse   Int    @db.SmallInt
  text    String

  @@index([book], map: "idx_16596_ixb")
  @@index([book, chapter, verse], map: "idx_16596_ixbcv")
  @@index([chapter], map: "idx_16596_ixc")
  @@index([verse], map: "idx_16596_ixv")
}

